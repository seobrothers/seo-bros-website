---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="About SEO Brothers | The Agency Behind Your Agency"
  description="SEO Brothers was built by agency owners, for agency owners. Learn how we became the trusted white-label SEO partner for 200+ agencies worldwide."
>
  <Nav />

  <!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
  <section class="about-hero">
    <div class="about-hero__bg">
      <div class="about-hero__orb about-hero__orb--1"></div>
      <div class="about-hero__orb about-hero__orb--2"></div>
      <div class="about-hero__orb about-hero__orb--3"></div>
      <div class="about-hero__grid-overlay"></div>
    </div>

    <div class="container about-hero__inner">
      <div class="about-hero__label" data-animate>
        <span class="about-hero__label-dot"></span>
        Our Story
      </div>

      <h1 class="about-hero__title" data-animate>
        Built by agencies.<br />
        <span class="about-hero__title-accent">For agencies.</span>
      </h1>

      <p class="about-hero__subtitle" data-animate>
        We started where you are — running an agency, juggling clients,
        and searching for an SEO partner we could actually trust.
        We never found one. So we became one.
      </p>

      <div class="about-hero__scroll-cue" data-animate>
        <div class="about-hero__scroll-line"></div>
        <span>Scroll to explore</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ ORIGIN STORY ═══════════════════════════════════ -->
  <section class="origin">
    <div class="container">
      <div class="origin__grid" data-animate>
        <div class="origin__content">
          <span class="section-label">The Beginning</span>
          <h2 class="origin__heading">
            We didn't set out to build an SEO company.
          </h2>
          <p class="origin__text">
            We were running a digital agency — managing PPC, web design, and yes,
            SEO — when we hit the same wall every growing agency hits. Clients
            wanted more SEO. We needed to deliver. But hiring in-house was
            expensive, outsourcing was unreliable, and the "white-label" options
            out there felt like they were run by people who'd never actually sat
            across from a client.
          </p>
          <p class="origin__text">
            So we built the service we wished existed. One that understands agency
            life — the pressure of client calls, the stakes of monthly reports,
            the need for a partner who performs like an extension of your team,
            not a faceless vendor.
          </p>
        </div>

        <div class="origin__timeline">
          <div class="origin__milestone" data-animate>
            <span class="origin__year">2014</span>
            <div class="origin__milestone-content">
              <h3>Agency Roots</h3>
              <p>
                Started as a full-service digital agency, learning firsthand
                what agencies need from a partner.
              </p>
            </div>
          </div>
          <div class="origin__milestone" data-animate>
            <span class="origin__year">2017</span>
            <div class="origin__milestone-content">
              <h3>The Pivot</h3>
              <p>
                Began offering white-label SEO after other agencies kept asking
                how we ran our campaigns so effectively.
              </p>
            </div>
          </div>
          <div class="origin__milestone" data-animate>
            <span class="origin__year">2020</span>
            <div class="origin__milestone-content">
              <h3>Going All-In</h3>
              <p>
                Transitioned fully to white-label, investing in the processes,
                team, and technology to serve agencies at scale.
              </p>
            </div>
          </div>
          <div class="origin__milestone" data-animate>
            <span class="origin__year">Now</span>
            <div class="origin__milestone-content">
              <h3>200+ Agency Partners</h3>
              <p>
                Trusted by agencies across every vertical to deliver campaigns
                their clients love — all under their brand.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ STATS ═══════════════════════════════════════════ -->
  <section class="stats">
    <div class="stats__bg">
      <div class="stats__orb stats__orb--1"></div>
      <div class="stats__orb stats__orb--2"></div>
    </div>
    <div class="container">
      <div class="stats__grid" data-stagger>
        <div class="stats__item" data-animate>
          <span class="stats__number" data-count="200">0</span>
          <span class="stats__suffix">+</span>
          <p class="stats__label">Agency Partners</p>
        </div>
        <div class="stats__item" data-animate>
          <span class="stats__number" data-count="5000">0</span>
          <span class="stats__suffix">+</span>
          <p class="stats__label">Campaigns Delivered</p>
        </div>
        <div class="stats__item" data-animate>
          <span class="stats__number" data-count="10">0</span>
          <span class="stats__suffix">+</span>
          <p class="stats__label">Years of Experience</p>
        </div>
        <div class="stats__item" data-animate>
          <span class="stats__number" data-count="50">0</span>
          <span class="stats__suffix">%+</span>
          <p class="stats__label">Avg. Partner Margin</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ MANIFESTO ═══════════════════════════════════════ -->
  <section class="manifesto">
    <div class="container">
      <div class="manifesto__inner" data-animate>
        <span class="section-label">What We Believe</span>
        <blockquote class="manifesto__quote">
          Great agencies shouldn't have to choose between
          <em>growing their SEO offering</em> and
          <em>maintaining the quality</em> that built their reputation.
        </blockquote>
        <div class="manifesto__beliefs" data-stagger>
          <div class="manifesto__belief" data-animate>
            <span class="manifesto__belief-num">01</span>
            <p>
              Your clients are <strong>your</strong> clients. We never contact
              them, compete with you, or undermine your relationships. Ever.
            </p>
          </div>
          <div class="manifesto__belief" data-animate>
            <span class="manifesto__belief-num">02</span>
            <p>
              Transparency isn't a feature — it's the foundation. You see
              everything we do, in real time, with nothing hidden.
            </p>
          </div>
          <div class="manifesto__belief" data-animate>
            <span class="manifesto__belief-num">03</span>
            <p>
              The best partnerships are built on results, not contracts.
              We earn your business every single month.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ VALUES BENTO ═══════════════════════════════════ -->
  <section class="values">
    <div class="container">
      <div class="values__header" data-animate>
        <span class="section-label--light">Our Values</span>
        <h2 class="section-heading--light">
          The principles that<br />shape everything we do
        </h2>
      </div>

      <div class="values__bento" data-stagger>
        <div class="values__card values__card--wide" data-animate>
          <div class="values__card-icon values__card-icon--teal">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="values__card-title">Radical Transparency</h3>
          <p class="values__card-text">
            No black-box tactics. No vague reports. You see exactly what we're doing,
            why we're doing it, and what results it's driving. Full access, always.
          </p>
        </div>

        <div class="values__card" data-animate>
          <div class="values__card-icon values__card-icon--purple">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="values__card-title">Agency-First</h3>
          <p class="values__card-text">
            We built this for agencies because we were one. Every process,
            report, and deliverable is designed for your workflow.
          </p>
        </div>

        <div class="values__card" data-animate>
          <div class="values__card-icon values__card-icon--green">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3 class="values__card-title">Results Over Rhetoric</h3>
          <p class="values__card-text">
            Rankings, traffic, conversions — the metrics that matter to your
            clients. No vanity metrics, no fluff.
          </p>
        </div>

        <div class="values__card" data-animate>
          <div class="values__card-icon values__card-icon--purple">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <h3 class="values__card-title">Scale Without Sacrifice</h3>
          <p class="values__card-text">
            Whether you have 5 SEO clients or 500, the quality stays
            the same. We grow with you, not against you.
          </p>
        </div>

        <div class="values__card values__card--wide" data-animate>
          <div class="values__card-icon values__card-icon--teal">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3 class="values__card-title">Genuine Partnership</h3>
          <p class="values__card-text">
            We don't do "set it and forget it." Your dedicated strategist knows your
            clients by name, joins your calls when needed, and celebrates your wins
            like they're our own — because they are.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ TEAM ═══════════════════════════════════════════ -->
  <section class="team">
    <div class="container">
      <div class="team__header" data-animate>
        <span class="section-label">Leadership</span>
        <h2 class="section-heading">The people behind the partnerships</h2>
        <p class="section-subtext">
          Agency veterans who've sat in your chair and understand
          what it takes to deliver for clients.
        </p>
      </div>

      <div class="team__grid" data-stagger>
        <div class="team__member" data-animate>
          <div class="team__avatar">
            <span class="team__initials" style="--accent: var(--teal)">AB</span>
          </div>
          <h3 class="team__name">Adam Bate</h3>
          <p class="team__role">Co-Founder & CEO</p>
          <p class="team__bio">
            Former agency owner who spent a decade in the trenches before building
            the partner he always wished he had. Obsessed with process, margins,
            and making agencies look brilliant.
          </p>
          <div class="team__social">
            <a href="#" aria-label="LinkedIn" class="team__social-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="team__member" data-animate>
          <div class="team__avatar">
            <span class="team__initials" style="--accent: var(--purple)">NB</span>
          </div>
          <h3 class="team__name">Nick Bate</h3>
          <p class="team__role">Co-Founder & COO</p>
          <p class="team__bio">
            The operational engine behind SEO Brothers. Turns strategy into
            systems and systems into results. If something runs smoothly,
            Nick probably designed the workflow.
          </p>
          <div class="team__social">
            <a href="#" aria-label="LinkedIn" class="team__social-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="team__member" data-animate>
          <div class="team__avatar">
            <span class="team__initials" style="--accent: var(--green)">TB</span>
          </div>
          <h3 class="team__name">Tom Bate</h3>
          <p class="team__role">Co-Founder & CTO</p>
          <p class="team__bio">
            The technical mind building the tools and infrastructure that
            let us scale without compromising quality. From dashboards to
            automation, Tom makes it all work seamlessly.
          </p>
          <div class="team__social">
            <a href="#" aria-label="LinkedIn" class="team__social-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ MARQUEE ═══════════════════════════════════════ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      <span class="marquee__item">Transparent</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Agency-First</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Results-Driven</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">White-Label</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Scalable</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Trusted</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Transparent</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Agency-First</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Results-Driven</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">White-Label</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Scalable</span>
      <span class="marquee__divider">&bull;</span>
      <span class="marquee__item">Trusted</span>
      <span class="marquee__divider">&bull;</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ CTA ═══════════════════════════════════════════ -->
  <section class="about-cta">
    <div class="about-cta__bg">
      <div class="about-cta__orb about-cta__orb--1"></div>
      <div class="about-cta__orb about-cta__orb--2"></div>
    </div>
    <div class="container about-cta__inner" data-animate>
      <h2 class="about-cta__heading">
        Ready to see what a real<br />partnership looks like?
      </h2>
      <p class="about-cta__text">
        No contracts. No minimums. Just a conversation about how we
        can help your agency grow its SEO offering — profitably.
      </p>
      <div class="about-cta__actions">
        <a href="#book-call" class="btn btn-primary btn-lg">
          Book a Call
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="/pricing" class="btn btn-outline">View Pricing</a>
      </div>
      <div class="about-cta__meta">
        <span class="about-cta__meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          No long-term contracts
        </span>
        <span class="about-cta__meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Free strategy session
        </span>
        <span class="about-cta__meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          100% white-label
        </span>
      </div>
    </div>
  </section>

  <Footer />

  <!-- ═══════════════ COUNTER ANIMATION SCRIPT ═══════════════ -->
  <script>
    function animateCounters() {
      const counters = document.querySelectorAll("[data-count]");
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const target = parseInt(el.dataset.count || "0", 10);
              const duration = 2000;
              const start = performance.now();

              function update(now: number) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 4);
                el.textContent = Math.round(eased * target).toLocaleString();
                if (progress < 1) requestAnimationFrame(update);
              }

              requestAnimationFrame(update);
              counterObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.3 }
      );

      counters.forEach((c) => counterObserver.observe(c));
    }

    animateCounters();
  </script>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════════════ */
  .about-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--dark);
    overflow: hidden;
  }

  .about-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .about-hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    animation: hero-float 20s ease-in-out infinite;
  }

  .about-hero__orb--1 {
    width: 500px;
    height: 500px;
    background: var(--teal);
    top: -10%;
    right: -5%;
    animation-delay: 0s;
  }

  .about-hero__orb--2 {
    width: 400px;
    height: 400px;
    background: var(--purple);
    bottom: -15%;
    left: -10%;
    animation-delay: -7s;
  }

  .about-hero__orb--3 {
    width: 300px;
    height: 300px;
    background: var(--green);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.08;
    animation-delay: -14s;
  }

  .about-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  @keyframes hero-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 15px) scale(0.95); }
  }

  .about-hero__inner {
    position: relative;
    z-index: 1;
    padding: 180px 24px 120px;
    max-width: 860px;
  }

  .about-hero__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-light);
    margin-bottom: 32px;
  }

  .about-hero__label-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(68, 185, 123, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(68, 185, 123, 0); }
  }

  .about-hero__title {
    font-family: var(--font-display);
    font-size: clamp(42px, 7vw, 80px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-on-dark);
    margin-bottom: 32px;
  }

  .about-hero__title-accent {
    background: linear-gradient(135deg, var(--teal) 0%, var(--purple) 60%, var(--green) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .about-hero__subtitle {
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.7;
    color: var(--text-on-dark-muted);
    max-width: 600px;
    margin-bottom: 0;
  }

  .about-hero__scroll-cue {
    position: absolute;
    bottom: 48px;
    left: 24px;
