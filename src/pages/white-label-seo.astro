<style>
  /* ===== HERO ===== */
  .wl-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--dark);
    overflow: hidden;
    padding: 140px 0 100px;
  }

  .wl-hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .wl-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.35;
    animation: wlFloat 20s ease-in-out infinite;
  }

  .wl-hero-orb--teal {
    width: 600px;
    height: 600px;
    background: var(--teal);
    top: -15%;
    left: -5%;
  }

  .wl-hero-orb--purple {
    width: 500px;
    height: 500px;
    background: var(--purple);
    top: -5%;
    right: -10%;
    animation-delay: -7s;
  }

  .wl-hero-orb--green {
    width: 400px;
    height: 400px;
    background: var(--green);
    bottom: -15%;
    left: 35%;
    animation-delay: -14s;
  }

  .wl-hero-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        rgba(255, 255, 255, 0.03) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.03) 1px,
        transparent 1px
      );
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse at 50% 50%,
      black 20%,
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      ellipse at 50% 50%,
      black 20%,
      transparent 70%
    );
  }

  @keyframes wlFloat {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -30px) scale(1.05);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.95);
    }
  }

  .wl-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .wl-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full);
    padding: 8px 16px;
    margin-bottom: 32px;
    backdrop-filter: blur(8px);
  }

  .wl-hero-badge-dot {
    width: 6px;
    height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: wlPulse 2s ease-in-out infinite;
  }

  @keyframes wlPulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(68, 185, 123, 0.4);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(68, 185, 123, 0);
    }
  }

  .wl-hero-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-on-dark);
    margin-bottom: 24px;
  }

  .wl-hero-title-gradient {
    background: linear-gradient(
      135deg,
