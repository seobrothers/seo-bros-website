---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const processSteps = [
  {
    number: "01",
    title: "World-Class Free Discovery",
    description:
      "We offer free audits that others charge thousands for. We identify opportunities, assess competition, and support your sales efforts before you commit to anything. No other white-label provider offers this.",
  },
  {
    number: "02",
    title: "Strategic Campaign Onboarding",
    description:
      "Every campaign starts with our strategic onboard — identifying priorities, capitalizing on quick wins, and laying out a clear roadmap. Your account manager walks you through every detail.",
  },
  {
    number: "03",
    title: "Quarterly Campaign Planning",
    description:
      "This is where we separate ourselves. Instead of obsessing over keyword counts, we take a strategic approach that balances performance, business priorities, competition, and opportunity.",
  },
  {
    number: "04",
    title: "Optimize, Implement, Execute",
    description:
      "On-page optimizations, content marketing, technical improvements, link acquisition, and more — all driven by the quarterly strategic plan for each campaign.",
  },
  {
    number: "05",
    title: "Reports & Dashboards",
    description:
      "White-label branded reports and real-time data dashboards you can reference at any point. Always know what is happening across all of your campaigns.",
  },
];

const components = [
  {
    icon: "strategy",
    title: "Quality Onboarding & Strategy",
    description:
      "Every campaign starts with our strategic onboarding month — setting the campaign up for success while capitalizing on quick wins.",
  },
  {
    icon: "keywords",
    title: "Keyword Research & Mapping",
    description:
      "The backbone of campaign success. Understanding existing content, identifying gaps, and mapping keywords to the right pages.",
  },
  {
    icon: "onpage",
    title: "On-Page Optimizations",
    description:
      "Page-specific meta data, headers, body copy, and content optimized to improve relevance and search visibility.",
  },
  {
    icon: "technical",
    title: "Technical SEO & Crawl Fixes",
    description:
      "Page speed, schema, broken links, canonical tags, and other technical elements reviewed and improved continuously.",
  },
  {
    icon: "links",
    title: "High-Quality Link Acquisition",
    description:
      "Quality links from authoritative sources with well-balanced anchor text for long-term website authority and campaign success.",
  },
  {
    icon: "local",
    title: "GBP & Local SEO",
    description:
      "Strategic GBP profile improvements, local citation building, and geo-targeted optimization for local map visibility.",
  },
  {
    icon: "content",
    title: "Strategic Content Marketing",
    description:
      "Improvements to existing pages, new content creation, and blog support to build topical authority and relevance.",
  },
  {
    icon: "reporting",
    title: "Reporting & Data Access",
    description:
      "Real-time campaign data dashboards and formatted monthly reports delivered to your inbox on the first of every month.",
  },
];

const faqs = [
  {
    question: "What exactly is white label SEO?",
    answer:
      "White label SEO is when you partner with an SEO provider (like us) who delivers SEO services under your agency's brand. Your clients see your branding on reports and communications — they never know we exist. It allows you to offer expert SEO services without hiring in-house or building the infrastructure yourself.",
  },
  {
    question: "How is this different from reseller SEO packages?",
    answer:
      "Reseller SEO is typically a pre-set package of actions at a fixed price with limited customization and support. White label SEO with SEO Brothers gives you access to a dedicated team, strategic guidance, education, and campaigns tailored to each client's needs. We combine the best of both — the predictability of reseller packages with the strategic depth of a true white-label partnership.",
  },
  {
    question: "What kind of margins can I expect?",
    answer:
      "Most of our partners experience 50%+ gross service margins on their SEO offerings. We work with you to price campaigns at a point that makes sense for your business while delivering exceptional value to your clients.",
  },
  {
    question: "Do I need SEO experience to get started?",
    answer:
      "Not at all. That's the beauty of a true white-label partnership. We provide the SEO expertise, training, and support. Many of our most successful partners came to us with little to no SEO experience. Your dedicated account manager will help you understand the process and communicate effectively with your clients.",
  },
  {
    question: "How long before I see results for my clients?",
    answer:
      "SEO is a long-term strategy, but our onboarding process is designed to capitalize on quick wins. Most campaigns start showing meaningful movement within the first 3-4 months, with compounding results over time. Your account manager will set clear expectations during the discovery process.",
  },
  {
    question: "Can I start with just one campaign?",
    answer:
      "Absolutely. Many of our partners start with a single campaign to test the process before scaling. There's no minimum commitment — start with one campaign and grow at your own pace.",
  },
  {
    question: "What does the partner portal include?",
    answer:
      "Our self-serve partner portal lets you order new campaigns, manage billing (start, stop, upgrade, downgrade), access real-time campaign data, communicate with your team through our support system, and add team members for collaboration. Everything you need in one place.",
  },
  {
    question: "Do you offer any kind of free trial or audit?",
    answer:
      "We offer unlimited free discovery audits to all partners. These audits are the same quality that competitors charge thousands for, and they help you identify good-fit campaigns, support your sales process, and close more deals.",
  },
];
---

<Layout
  title="White Label SEO Services | SEO Brothers"
  description="Partner with SEO Brothers for white label SEO services. No upfront cost, dedicated campaign managers, and 50%+ margins for your agency."
>
  <Nav />

  <!-- ===== HERO ===== -->
  <section class="wl-hero">
    <div class="wl-hero-bg">
      <div class="wl-hero-orb wl-hero-orb--teal"></div>
      <div class="wl-hero-orb wl-hero-orb--purple"></div>
      <div class="wl-hero-orb wl-hero-orb--green"></div>
      <div class="wl-hero-grid"></div>
    </div>

    <div class="wl-hero-content container">
      <div class="wl-hero-badge" data-animate>
        <span class="wl-hero-badge-dot"></span>
        Trusted by 200+ agency partners
      </div>

      <h1 class="wl-hero-title" data-animate>
        White Label SEO<br />
        <span class="wl-hero-title-gradient">Without the Headaches</span>
      </h1>

      <p class="wl-hero-subtitle" data-animate>
        No up-front cost. Dedicated campaign manager. Effortless scaling.
        Deliver expert SEO services under your own brand while keeping 50%+
        margins.
      </p>

      <div class="wl-hero-actions" data-animate>
        <a href="#wl-cta" class="btn btn-primary wl-btn-lg">
          Book a Good Fit Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href="#demo" class="btn btn-outline">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle
              cx="8"
              cy="8"
              r="6"
              stroke="currentColor"
              stroke-width="1.5"></circle>
            <path d="M6.5 5.5l4 2.5-4 2.5V5.5z" fill="currentColor"></path>
          </svg>
          Watch a Demo
        </a>
      </div>

      <div class="wl-hero-pills" data-animate>
        <span class="wl-hero-pill">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          No upfront cost
        </span>
        <span class="wl-hero-pill">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          Cancel anytime
        </span>
        <span class="wl-hero-pill">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          Free discovery audits
        </span>
      </div>
    </div>
  </section>

  <!-- ===== WHAT IS WHITE LABEL SEO ===== -->
  <section class="wl-what">
    <div class="container">
      <div class="wl-what-grid">
        <div class="wl-what-content" data-animate>
          <span class="section-label">More Than a Reseller</span>
          <h2 class="section-heading">
            What is White Label SEO<br />
            at SEO Brothers?
          </h2>
          <p class="wl-what-text">
            White Label SEO at SEO Brothers involves a <strong
              >true partnership</strong
            >. We are more than a basic reseller solution. We enable your
            marketing or digital agency to offer and sell organic SEO services to
            your clients without hiring an in-house team or piecing together
            outsourced contractors.
          </p>
          <p class="wl-what-text">
            You deliver high-quality SEO services through your own brand without
            having to do any of the work — oftentimes while still leaving plenty
            of margin for your business.
          </p>
        </div>
        <div class="wl-what-benefits" data-animate>
          <div class="wl-benefit-card">
            <div class="wl-benefit-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="wl-benefit-title">Fully White-Labeled</h3>
              <p class="wl-benefit-desc">
                Your brand on every report, dashboard, and deliverable. Your
                clients never know we exist.
              </p>
            </div>
          </div>
          <div class="wl-benefit-card">
            <div class="wl-benefit-icon wl-benefit-icon--purple">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                ></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <div>
              <h3 class="wl-benefit-title">No Hiring Required</h3>
              <p class="wl-benefit-desc">
                Skip the $50k+ salary, training, and management overhead. Get a
                full SEO team instantly.
              </p>
            </div>
          </div>
          <div class="wl-benefit-card">
            <div class="wl-benefit-icon wl-benefit-icon--green">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                <polyline points="17 6 23 6 23 12"></polyline>
              </svg>
            </div>
            <div>
              <h3 class="wl-benefit-title">50%+ Service Margins</h3>
              <p class="wl-benefit-desc">
                Pricing structured to ensure healthy margins for your agency from
                day one.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROVEN PROCESS ===== -->
  <section class="wl-process">
    <div class="container">
      <div class="wl-process-header" data-animate>
        <span class="section-label">Proven Campaign Process</span>
        <h2 class="section-heading">
          SEO Brothers' White Label<br />
          Campaign Success Formula
        </h2>
        <p class="section-subtext" style="margin:0 auto;">
          We follow a proven process to ensure you can bring to market a highly
          profitable SEO solution while providing the best value to your clients.
        </p>
      </div>

      <div class="wl-process-timeline">
        <div class="wl-process-line"></div>
        {
          processSteps.map((step) => (
            <div class="wl-process-step" data-animate>
              <div class="wl-process-marker">
                <span class="wl-process-number">{step.number}</span>
              </div>
              <div class="wl-process-step-body">
                <h3 class="wl-process-step-title">{step.title}</h3>
                <p class="wl-process-step-desc">{step.description}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="wl-process-cta" data-animate>
        <a href="#wl-cta" class="btn btn-primary">
          Start With Free Discovery
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CAMPAIGN COMPONENTS ===== -->
  <section class="wl-components">
    <div class="container">
      <div class="wl-components-header" data-animate>
        <span class="section-label">What's Included</span>
        <h2 class="section-heading">
          White Label SEO<br />
          Campaign Components
        </h2>
        <p class="section-subtext" style="margin:0 auto;">
          We combine essential SEO components with quality reporting and the
          ability to scale each campaign up and down as needed.
        </p>
      </div>

      <div class="wl-components-grid" data-stagger>
        {
          components.map((comp, i) => (
            <div class="wl-comp-card" data-animate>
              <div
                class={`wl-comp-icon wl-comp-icon--${i % 3 === 0 ? "teal" : i % 3 === 1 ? "purple" : "green"}`}
              >
                {comp.icon === "strategy" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                  </svg>
                )}
                {comp.icon === "keywords" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  </svg>
                )}
                {comp.icon === "onpage" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                  </svg>
                )}
                {comp.icon === "technical" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                )}
                {comp.icon === "links" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                  </svg>
                )}
                {comp.icon === "local" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {comp.icon === "content" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                  </svg>
                )}
                {comp.icon === "reporting" && (
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                    <line x1="2" y1="20" x2="22" y2="20" />
                  </svg>
                )}
              </div>
              <h3 class="wl-comp-title">{comp.title}</h3>
              <p class="wl-comp-desc">{comp.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== PARTNER PORTAL ===== -->
  <section class="wl-portal">
    <div class="wl-portal-bg">
      <div class="wl-portal-orb wl-portal-orb--1"></div>
      <div class="wl-portal-orb wl-portal-orb--2"></div>
    </div>
    <div class="container">
      <div class="wl-portal-content" data-animate>
        <span class="section-label section-label--light"
          >Partner Portal</span
        >
        <h2 class="section-heading section-heading--light">
          Manage Everything<br />
          From One Place
        </h2>
        <p class="section-subtext section-subtext--light">
          Our self-serve partner portal takes the hassle out of ordering
          campaigns, getting support, and having visibility on existing
          campaigns.
        </p>
      </div>

      <div class="wl-portal-grid" data-stagger>
        <div class="wl-portal-feature" data-animate>
          <div class="wl-portal-feature-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2"
              ></rect>
              <line x1="1" y1="10" x2="23" y2="10"></line>
            </svg>
          </div>
          <h3 class="wl-portal-feature-title">Order & Manage Billing</h3>
          <p class="wl-portal-feature-desc">
            Order white label SEO campaigns and projects. Start, stop,
            upgrade, or downgrade with self-serve billing.
          </p>
        </div>

        <div class="wl-portal-feature" data-animate>
          <div class="wl-portal-feature-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
              ></path>
            </svg>
          </div>
          <h3 class="wl-portal-feature-title">Support When You Need It</h3>
          <p class="wl-portal-feature-desc">
            Access our partner-only knowledge base or start a conversation
            with your team for campaign questions and support.
          </p>
        </div>

        <div class="wl-portal-feature" data-animate>
          <div class="wl-portal-feature-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
              ></path>
              <circle cx="9" cy="7" r="4"></circle>
              <line x1="19" y1="8" x2="19" y2="14"></line>
              <line x1="22" y1="11" x2="16" y2="11"></line>
            </svg>
          </div>
          <h3 class="wl-portal-feature-title">Add Team Members</h3>
          <p class="wl-portal-feature-desc">
            Add multiple people to your account — great for agencies with
            multiple account managers overseeing different clients.
          </p>
        </div>
      </div>

      <div class="wl-portal-mockup" data-animate>
        <div class="wl-portal-mockup-inner">
          <div class="wl-portal-mockup-bar">
            <div class="wl-portal-mockup-dots">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <span class="wl-portal-mockup-url">portal.seobrothers.com</span>
          </div>
          <div class="wl-portal-mockup-body">
            <div class="wl-portal-mockup-placeholder">
              [Image: Partner portal dashboard — campaign management interface
              showing active campaigns, performance metrics, and quick actions]
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== POPULAR PRODUCTS ===== -->
  <section class="wl-products">
    <div class="container">
      <div class="wl-products-header" data-animate>
        <span class="section-label">Our Products</span>
        <h2 class="section-heading">
          Most Popular White Label<br />
          SEO Products
        </h2>
        <p class="section-subtext" style="margin:0 auto;">
          From full managed campaigns to standalone services — pick what your
          clients need most.
        </p>
      </div>

      <div class="wl-products-grid" data-stagger>
        <div class="wl-product-card wl-product-card--featured" data-animate>
          <span class="wl-product-badge">Most Popular</span>
          <h3 class="wl-product-title">Managed SEO Campaigns</h3>
          <p class="wl-product-desc">
            By far the most popular, most valuable, and most profitable. Our
            strategic managed campaigns are what we specialize in — the full
            package your clients need to drive massive organic value.
          </p>
          <a href="#wl-cta" class="btn btn-primary wl-product-btn"
            >Get Started</a
          >
        </div>

        <div class="wl-product-card" data-animate>
          <h3 class="wl-product-title">One-Time Optimizations</h3>
          <p class="wl-product-desc">
            Not every client is ready for ongoing SEO. Our one-time projects
            with defined scope and deliverables provide excellent value and
            results without the ongoing commitment. Redesign consultations
            available too.
          </p>
          <a
            href="#wl-cta"
            class="btn btn-outline--dark wl-product-btn"
            >Learn More</a
          >
        </div>

        <div class="wl-product-card" data-animate>
          <h3 class="wl-product-title">Link Acquisition Plans</h3>
          <p class="wl-product-desc">
            Acquire high-quality, relevant links you won't find anywhere else.
            Our link building plans let you focus purely on authority building
            when that's the biggest need for a campaign.
          </p>
          <a
            href="#wl-cta"
            class="btn btn-outline--dark wl-product-btn"
            >Learn More</a
          >
        </div>

        <div class="wl-product-card" data-animate>
          <h3 class="wl-product-title">Content Marketing</h3>
          <p class="wl-product-desc">
            Whether you need strategic support building out new content, an
            ongoing content marketing plan, or end-to-end creation — our managed
            content plans put that into action.
          </p>
          <a
            href="#wl-cta"
            class="btn btn-outline--dark wl-product-btn"
            >Learn More</a
          >
        </div>
      </div>
