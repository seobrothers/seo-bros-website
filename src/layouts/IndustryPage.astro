---
import Layout from "./Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface ServiceItem {
  icon: string;
  title: string;
  description: string;
}

interface GuideSectionItem {
  id: string;
  title: string;
  content: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface TestimonialItem {
  text: string;
  name: string;
  role: string;
  initials: string;
  color?: "teal" | "purple" | "green";
}

interface ApproachItem {
  title: string;
  description: string;
}

interface Props {
  industry: string;
  industrySlug: string;
  seoTitle: string;
  seoDescription: string;
  heroTitle: string;
  heroSubtitle: string;
  heroBadge?: string;
  heroFormHeading?: string;
  whyItMatters: {
    title: string;
    description: string;
    stats: Array<{ value: string; label: string }>;
  };
  services: ServiceItem[];
  servicesHeading?: string;
  approach: {
    label?: string;
    title: string;
    description: string;
    contrast?: { dont: string[]; do: string[] };
    items: ApproachItem[];
  };
  testimonials?: TestimonialItem[];
  guideIntro?: string;
  guideContent: GuideSectionItem[];
  guideHeading?: string;
  faqs: FaqItem[];
  ctaHeading?: string;
  ctaText?: string;
  midCtaHeading?: string;
  midCtaText?: string;
  floatingCtaText?: string;
}

const {
  industry,
  industrySlug,
  seoTitle,
  seoDescription,
  heroTitle,
  heroSubtitle,
  heroBadge = "Trusted by 200+ local service businesses",
  heroFormHeading = "Get Your Free Strategy Call",
  whyItMatters,
  services,
  servicesHeading,
  approach,
  testimonials = [],
  guideIntro,
  guideContent,
  guideHeading,
  faqs,
  ctaHeading = `Ready to Grow Your ${industry} Business?`,
  ctaText = "Get a free visibility audit. We'll show you exactly where you stand online, where the opportunity is, and how to take advantage of it.",
  midCtaHeading,
  midCtaText = "Get a free visibility audit — we'll show you where you stand and where you're leaving money on the table.",
  floatingCtaText,
} = Astro.props;

const iconColors = ["teal", "purple", "green"];
const avatarColors = { teal: "teal", purple: "purple", green: "green" };
---

<Layout title={seoTitle} description={seoDescription}>
  <Nav />

  <!-- ===== HERO ===== -->
  <section class="ind-hero" id="ind-hero">
    <div class="ind-hero-bg">
      <div class="ind-hero-orb ind-hero-orb--teal"></div>
      <div class="ind-hero-orb ind-hero-orb--purple"></div>
      <div class="ind-hero-orb ind-hero-orb--green"></div>
      <div class="ind-hero-grid"></div>
    </div>
    <div class="ind-hero-inner container">
      <div class="ind-hero-content">
        <div class="ind-hero-badge" data-animate>
          <span class="ind-hero-badge-dot"></span>
          {heroBadge}
        </div>
        <h1 class="ind-hero-title" data-animate>
          <span class="ind-hero-title-gradient" set:html={heroTitle} />
        </h1>
        <p class="ind-hero-subtitle" data-animate>{heroSubtitle}</p>
        <div class="ind-hero-trust" data-animate>
          <div class="ind-hero-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            No contracts
          </div>
          <div class="ind-hero-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Free visibility audit
          </div>
          <div class="ind-hero-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Cancel anytime
          </div>
        </div>
      </div>

      <div class="ind-hero-form-wrap" data-animate>
        <div class="ind-hero-form-card">
          <h2 class="ind-hero-form-heading">{heroFormHeading}</h2>
          <p class="ind-hero-form-sub">Enter your details and we'll show you exactly where you stand online.</p>
          <form class="ind-hero-form" id="hero-form">
            <div class="ind-form-field">
              <label for="ind-name">Your Name</label>
              <input type="text" id="ind-name" name="name" placeholder="John Smith" required data-lpignore="true" autocomplete="off" />
            </div>
            <div class="ind-form-field">
              <label for="ind-company">Business Name</label>
              <input type="text" id="ind-company" name="company" placeholder="Smith's Plumbing" required data-lpignore="true" autocomplete="off" />
            </div>
            <div class="ind-form-row">
              <div class="ind-form-field">
                <label for="ind-phone">Phone</label>
                <input type="tel" id="ind-phone" name="phone" placeholder="(555) 123-4567" required data-lpignore="true" autocomplete="off" />
              </div>
              <div class="ind-form-field">
                <label for="ind-email">Email</label>
                <input type="email" id="ind-email" name="email" placeholder="john@email.com" required data-lpignore="true" autocomplete="off" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary ind-form-submit">
              Get My Free Visibility Audit
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <p class="ind-form-disclaimer">Free. No commitment. Takes 30 seconds.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="ind-why">
    <div class="container">
      <div class="ind-why-top" data-animate>
        <span class="section-label">Why It Matters</span>
        <h2 class="section-heading">{whyItMatters.title}</h2>
        <p class="section-subtext" style="margin:0 auto;">{whyItMatters.description}</p>
      </div>
      <div class="ind-why-stats" data-stagger>
        {whyItMatters.stats.map((stat) => (
          <div class="ind-stat" data-animate>
            <span class="ind-stat-value">{stat.value}</span>
            <span class="ind-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="ind-services">
    <div class="container">
      <div class="ind-services-header" data-animate>
        <span class="section-label">What We Do</span>
        <h2 class="section-heading" set:html={servicesHeading || `What We Do to Get Your<br />${industry} Business Found`} />
      </div>
      <div class="ind-services-grid" data-stagger>
        {services.map((svc, i) => (
          <div class="ind-svc-card" data-animate>
            <div class={`ind-svc-icon ind-svc-icon--${iconColors[i % 3]}`}>
              {svc.icon === "map-pin" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>}
              {svc.icon === "edit" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>}
              {svc.icon === "link" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>}
              {svc.icon === "star" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>}
              {svc.icon === "globe" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>}
              {svc.icon === "code" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>}
              {svc.icon === "file-text" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>}
              {svc.icon === "bar-chart" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>}
              {svc.icon === "search" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>}
              {svc.icon === "smartphone" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>}
              {svc.icon === "shield" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {svc.icon === "phone" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
            </div>
            <h3 class="ind-svc-title">{svc.title}</h3>
            <p class="ind-svc-desc">{svc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OUR APPROACH ===== -->
  <section class="ind-approach">
    <div class="container">
      <div class="ind-approach-header" data-animate>
        <span class="section-label">{approach.label || "Our Approach"}</span>
        <h2 class="section-heading" set:html={approach.title} />
        <p class="section-subtext" style="margin:0 auto;" set:html={approach.description} />
      </div>

      {approach.contrast && (
        <div class="ind-approach-contrast" data-animate>
          <div class="ind-contrast-col ind-contrast-col--dont">
            <div class="ind-contrast-header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              <span>We don't</span>
            </div>
            {approach.contrast.dont.map((item) => (
              <p class="ind-contrast-item">{item}</p>
            ))}
          </div>
          <div class="ind-contrast-col ind-contrast-col--do">
            <div class="ind-contrast-header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>We do</span>
            </div>
            {approach.contrast.do.map((item) => (
              <p class="ind-contrast-item">{item}</p>
            ))}
          </div>
        </div>
      )}

      <div class="ind-approach-grid" data-stagger>
        {approach.items.map((item, i) => (
          <div class="ind-approach-card" data-animate>
            <div class={`ind-approach-num ind-approach-num--${iconColors[i % 3]}`}>{String(i + 1).padStart(2, '0')}</div>
            <h3 class="ind-approach-title">{item.title}</h3>
            <p class="ind-approach-desc">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  {testimonials.length > 0 && (
    <section class="ind-testimonials">
      <div class="container">
        <div class="ind-testimonials-header" data-animate>
          <span class="section-label">Real Results</span>
          <h2 class="section-heading">What Our Clients Say</h2>
        </div>
        <div class="ind-testimonials-grid" data-stagger>
          {testimonials.map((t) => (
            <blockquote class="ind-testimonial" data-animate>
              <div class="ind-testimonial-quote">
                <svg class="ind-testimonial-mark" width="36" height="36" viewBox="0 0 40 40" fill="none">
                  <path d="M18 20H10C10 15.58 13.58 12 18 12V8C11.37 8 6 13.37 6 20V32H18V20ZM38 20H30C30 15.58 33.58 12 38 12V8C31.37 8 26 13.37 26 20V32H38V20Z" fill="currentColor"/>
                </svg>
                <p class="ind-testimonial-text">{t.text}</p>
              </div>
              <div class="ind-testimonial-author">
                <div class={`ind-testimonial-avatar ind-testimonial-avatar--${t.color || "teal"}`}>{t.initials}</div>
                <div>
                  <div class="ind-testimonial-name">{t.name}</div>
                  <div class="ind-testimonial-role">{t.role}</div>
                </div>
              </div>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== MID CTA ===== -->
  <section class="ind-mid-cta">
    <div class="ind-mid-cta-bg">
      <div class="ind-mid-cta-orb ind-mid-cta-orb--1"></div>
      <div class="ind-mid-cta-orb ind-mid-cta-orb--2"></div>
    </div>
    <div class="container">
      <div class="ind-mid-cta-content" data-animate>
        <h2 class="ind-mid-cta-heading" set:html={midCtaHeading || `Ready to Get More Customers<br/>From Online Search?`} />
        <p class="ind-mid-cta-text">{midCtaText}</p>
        <a href="#ind-hero" class="btn btn-primary ind-btn-lg">
          Get My Free Visibility Audit
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== GUIDE ===== -->
  <section class="ind-guide" id="guide">
    <div class="container">
      <div class="ind-guide-header" data-animate>
        <span class="section-label">The Complete Guide</span>
        <h2 class="section-heading" set:html={guideHeading || `SEO for ${industry}:<br/>Everything You Need to Know`} />
        {guideIntro && <p class="section-subtext" style="margin:0 auto;" set:html={guideIntro} />}
      </div>

      <div class="ind-guide-layout">
        <div class="ind-guide-main">
          {guideContent.map((section) => (
            <article class="ind-guide-section" id={section.id} data-animate>
              <h2 class="ind-guide-h2">{section.title}</h2>
              <div class="ind-guide-body" set:html={section.content} />
            </article>
          ))}
        </div>

        <aside class="ind-guide-toc">
          <div class="ind-guide-toc-inner" id="guide-toc">
            <span class="ind-guide-toc-label">On This Page</span>
            <nav>
              {guideContent.map((section) => (
                <a href={`#${section.id}`} class="ind-guide-toc-link" data-toc-link={section.id}>
                  {section.title}
                </a>
              ))}
            </nav>
            <div class="ind-guide-toc-cta">
              <a href="#ind-hero" class="btn btn-primary" style="width:100%; font-size:13px; padding:10px 16px;">Get a Free Visibility Audit</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="ind-faq">
    <div class="container">
      <div class="ind-faq-header" data-animate>
        <span class="section-label">Common Questions</span>
        <h2 class="section-heading">{industry} SEO<br />Frequently Asked Questions</h2>
      </div>
      <div class="ind-faq-list" data-animate>
        {faqs.map((faq, i) => (
          <details class="ind-faq-item" open={i === 0}>
            <summary class="ind-faq-question">
              <span>{faq.question}</span>
              <svg class="ind-faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="ind-faq-answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== BOTTOM CTA ===== -->
  <section class="ind-bottom-cta" id="ind-cta">
    <div class="ind-bottom-cta-bg">
      <div class="ind-bottom-cta-orb ind-bottom-cta-orb--1"></div>
      <div class="ind-bottom-cta-orb ind-bottom-cta-orb--2"></div>
    </div>
    <div class="container">
      <div class="ind-bottom-cta-content" data-animate>
        <h2 class="ind-bottom-cta-heading" set:html={ctaHeading} />
        <p class="ind-bottom-cta-text">{ctaText}</p>
        <div class="ind-bottom-cta-actions">
          <a href="#ind-hero" class="btn btn-primary ind-btn-lg">
            Get My Free Visibility Audit
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="ind-bottom-cta-meta">
          <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> No contracts</span>
          <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Free visibility audit</span>
          <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Cancel anytime</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FLOATING CTA BAR ===== -->
  <div class="ind-float-cta" id="float-cta">
    <div class="ind-float-cta-inner container">
      <span class="ind-float-cta-text">{floatingCtaText || `Ready to grow your ${industry.toLowerCase()} business?`}</span>
      <a href="#ind-hero" class="btn btn-primary ind-float-cta-btn">Get a Free Visibility Audit</a>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // Floating CTA: show after scrolling past hero
  const floatCta = document.getElementById("float-cta");
  const hero = document.getElementById("ind-hero");

  if (floatCta && hero) {
    const heroObserver = new IntersectionObserver(
      ([entry]) => {
        floatCta.classList.toggle("visible", !entry.isIntersecting);
      },
      { threshold: 0 }
    );
    heroObserver.observe(hero);
  }

  // Sticky TOC: track active section
  const tocLinks = document.querySelectorAll("[data-toc-link]");
  const guideSections = document.querySelectorAll(".ind-guide-section");

  if (tocLinks.length > 0 && guideSections.length > 0) {
    const tocObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((link) => {
              link.classList.toggle(
                "active",
                (link as HTMLElement).dataset.tocLink === id
              );
            });
          }
        });
      },
      { rootMargin: "-100px 0px -60% 0px", threshold: 0 }
    );

    guideSections.forEach((section) => tocObserver.observe(section));
  }
</script>

<style>
  /* ===== HERO ===== */
  .ind-hero {
    position: relative;
    background: var(--dark);
    overflow: hidden;
    padding: 140px 0 100px;
  }

  .ind-hero-bg { position: absolute; inset: 0; overflow: hidden; }

  .ind-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.35;
    animation: indFloat 20s ease-in-out infinite;
  }

  .ind-hero-orb--teal { width: 600px; height: 600px; background: var(--teal); top: -15%; left: -5%; }
  .ind-hero-orb--purple { width: 500px; height: 500px; background: var(--purple); top: -5%; right: -10%; animation-delay: -7s; }
  .ind-hero-orb--green { width: 400px; height: 400px; background: var(--green); bottom: -15%; left: 35%; animation-delay: -14s; }

  .ind-hero-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
  }

  @keyframes indFloat {
    0%, 100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(30px,-30px) scale(1.05); }
    66% { transform: translate(-20px,20px) scale(0.95); }
  }

  .ind-hero-inner {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 56px;
    align-items: center;
  }

  .ind-hero-content { max-width: 600px; }

  .ind-hero-badge {
